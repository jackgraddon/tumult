{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Tumult",
  "version": "0.3.21-1",
  "identifier": "cc.jackg.tumult",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "corepack yarn dev",
    "beforeBuildCommand": "corepack yarn generate"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Tumult",
        "width": 1200,
        "minWidth": 1000,
        "height": 800,
        "minHeight": 500,
        "resizable": true,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self' https://tumult.jackg.cc; script-src 'self' https://tumult.jackg.cc; style-src 'self' 'unsafe-inline' https://tumult.jackg.cc; img-src 'self' blob: data: https://*.discordapp.com https://*.duckduckgo.com https://tumult.jackg.cc; connect-src 'self' ws://127.0.0.1:13337 ws://localhost:3000 http://localhost:3000 http://localhost:1420 https://*.matrix.org https://discord.com https://tumult.jackg.cc;"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://tumult.jackg.cc/api/update"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyNTE3RDE5Mjk3M0U1NDAKUldSQTVYTXBHWDFSa3FVWnRpK3habjZsdlZEc1VCMEE1emRTMjYwaTkxbzlnbFgzT29xa01JL0gK"
    }
  },
  "bundle": {
    "active": true,
    "publisher": "cc.jackg.tumult",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/arrpc"
    ],
    "targets": "all",
    "icon": [
      "icons/App.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "macOS": {
      "entitlements": "./entitlements.plist",
      "minimumSystemVersion": "10.15",
      "files": {
        "Resources/Assets.car": "resources/Assets.car"
      }
    }
  }
}