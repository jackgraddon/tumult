{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Tumult",
  "version": "0.0.3032",
  "identifier": "cc.jackg.tumult",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "corepack yarn dev",
    "beforeBuildCommand": "corepack yarn generate"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Tumult",
        "useHttpsScheme": true,
        "width": 1200,
        "minWidth": 1000,
        "height": 800,
        "minHeight": 500,
        "resizable": true,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "Tumult",
        "url": "/splash.html",
        "width": 300,
        "height": 450,
        "resizable": false,
        "decorations": false,
        "center": true,
        "transparent": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./entitlements.plist",
      "minimumSystemVersion": "10.15"
    }
  }
}