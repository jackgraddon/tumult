{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Tumult",
  "version": "0.0.3032",
  "identifier": "cc.jackg.tumult",
  "build": {
    "frontendDist": "../.output/public",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "corepack yarn dev",
    "beforeBuildCommand": "corepack yarn generate"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Tumult",
        "width": 1200,
        "minWidth": 1000,
        "height": 800,
        "minHeight": 500,
        "resizable": true,
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data: https://*.discordapp.com https://*.duckduckgo.com; connect-src 'self' ws://127.0.0.1:13337 ws://localhost:3000 http://localhost:3000 http://localhost:1420 https://*.matrix.org https://discord.com;"
    }
  },
  "bundle": {
    "active": true,
    "externalBin": [
      "binaries/arrpc"
    ],
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "./entitlements.plist",
      "minimumSystemVersion": "10.15"
    }
  }
}